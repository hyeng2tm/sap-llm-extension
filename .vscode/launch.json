{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Extension",
      "type": "extensionHost",
      "request": "launch",
      "preLaunchTask": "npm: watch",
      "stopOnEntry": false,

      "runtimeExecutable": "${execPath}",

      "args": [        
        "--extensionDevelopmentPath=${workspaceFolder}",
        "--user-data-dir=${workspaceFolder}/.vscode-dev"
      ],

      "outFiles": ["${workspaceFolder}/out/**/*.js"],

      "cwd": "${workspaceFolder}"
    }
  ]
}